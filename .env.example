# Supabase — 프로젝트 설정 > API 에서 확인
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# 서버 전용 비밀키 (NEXT_PUBLIC_ 금지 — 클라이언트 노출 절대 금지)
# Supabase service_role / secret 키. 서버 API 라우트에서만 사용.
SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# AI: OpenRouter (OpenAI 호환, baseURL=https://openrouter.ai/api/v1)
OPENROUTER_API_KEY=your-openrouter-api-key

# 도서 데이터: 알라딘 Open API (TTB 키)
ALADIN_TTB_KEY=your-aladin-ttb-key
